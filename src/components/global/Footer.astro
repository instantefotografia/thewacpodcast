---
// Assets
import LogoIcon from "@/components/assets/LogoIcon.astro";
// Fundations
import Text from "../fundations/elements/Text.astro";
import Wrapper from "../fundations/containers/Wrapper.astro";

const podcastPlatforms = [
  { name: "Spotify", link: "https://open.spotify.com/show/6CBDI1nNRGpOqMFsdvJbzO?si=d4a41214c2d8412a" },
  { name: "Apple Podcasts", link: "https://podcasts.apple.com/pt/podcast/the-wac-podcast/id1739397751" },
  { name: "YouTube", link: "https://www.youtube.com/@thewacpodcast" },
];

const siteLinks = [
  { name: "Podcast", link: "/podcast" },
  { name: "Blog", link: "/blog" },
  { name: "About", link: "/about" },
  { name: "Community", link: "/community" },
];

const socialLinks = [
  { name: "Instagram", link: "https://instagram.com/thewacpodcast" },
];
---

<footer class="z-0 w-full pb-2 bg-base-900">
  <Wrapper variant="standard" class="pt-12 lg:pt-12">
    <LogoIcon class="h-16 w-auto" variant="white" />

    <!-- Description left · nav columns right -->
    <div class="mt-12 flex flex-col md:flex-row md:justify-between gap-12">

      <!-- Description -->
      <div class="max-w-xs">
        <Text tag="p" variant="textSM" class="mt-2 text-base-400">
          The Wedding Artists Community is where photographers, planners, and
          creatives come to share honestly, build better, and connect with
          peers across the world.
        </Text>
      </div>

      <!-- Nav columns: Social · Listen On · Navigate -->
      <div class="flex flex-col sm:flex-row gap-8 sm:gap-12 lg:gap-16">

        <div>
          <Text tag="h3" variant="textXS" class="font-medium text-white uppercase tracking-wide">
            Social
          </Text>
          <nav class="flex flex-col mt-4 gap-2">
            {socialLinks.map((link) => (
              <Text
                tag="a"
                variant="textXS"
                href={link.link}
                target="_blank"
                rel="noopener noreferrer"
                class="font-medium uppercase text-base-300 hover:underline tracking-wide"
              >
                {link.name}
              </Text>
            ))}
          </nav>
        </div>

        <div>
          <Text tag="h3" variant="textXS" class="font-medium text-white uppercase tracking-wide">
            Listen on
          </Text>
          <nav class="flex flex-col mt-4 gap-2">
            {podcastPlatforms.map((platform) => (
              <Text
                tag="a"
                variant="textXS"
                href={platform.link}
                aria-label={`Listen on ${platform.name}`}
                class="font-medium uppercase text-base-300 hover:underline tracking-wide"
              >
                {platform.name}
              </Text>
            ))}
          </nav>
        </div>

        <div>
          <Text tag="h3" variant="textXS" class="font-medium text-white uppercase tracking-wide">
            Navigate
          </Text>
          <nav class="flex flex-col mt-4 gap-2">
            {siteLinks.map((link) => (
              <Text
                tag="a"
                variant="textXS"
                href={link.link}
                class="font-medium uppercase text-base-300 hover:underline tracking-wide"
              >
                {link.name}
              </Text>
            ))}
          </nav>
        </div>

      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-base-800 text-center">
      <Text tag="span" class="text-xs font-medium text-white">
        © {new Date().getFullYear()} Wedding Artists Community. All rights reserved.
      </Text>
    </div>
  </Wrapper>
</footer>
