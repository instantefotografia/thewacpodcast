---
// Assets
import Logo from "@/components/assets/Logo.astro";
import BigLogo from "@/components/assets/BigLogo.astro";
import Signature from "@/components/global/Signature.astro";
// Fundations
import Text from "../fundations/elements/Text.astro";
import Wrapper from "../fundations/containers/Wrapper.astro";
const footerLinks = [
  {
    id: "listen-on",
    title: "Listen on",
    platforms: [
      { name: "Spotify", link: "#_" },
      { name: "Apple Podcasts", link: "#_" },
      { name: "YouTube", link: "#_" },
      { name: "Overcast", link: "#_" },
      { name: "Pocket Casts", link: "#_" },
      { name: "Castbox", link: "#_" },
      { name: "Stitcher", link: "#_" },
      { name: "iHeartRadio", link: "#_" },
      { name: "Google Podcasts", link: "#_" },
      { name: "Amazon Music", link: "#_" },
    ],
  },
  // Add more sections as needed
];
---

<footer class="pb-2 bg-black w-full z-0">
  <Wrapper variant="standard" class="pt-12 lg:pt-12">
    <BigLogo class="max-w-4xl text-white" />

    <div
      class="grid grid-cols-1 mt-12 md:grid-cols-2 gap-y-12 gap-x-12 items-start"
    >
      <div>
        <Text
          tag="p"
          variant="textSM"
          class="font-serif text-base-400 mt-2 max-w-xs"
        >
          Hemingway conducts in-depth interviews with some of the top design
          engineers in the industry, giving you the option to either read the
          full transcripts or listen to the conversations on a variety of
          platforms, ensuring accessibility and convenience for all audiences.

          <br />
          <br />
          These interviews delve into the creative processes, innovative solutions,
          and real-world challenges faced by design engineers, offering valuable
          insights and inspiration for professionals and enthusiasts alike. Whether
          you prefer to engage with the content on your morning commute or during
          a quiet moment at home, Hemingway makes it easy to stay connected to cutting-edge
          ideas in design engineering.
        </Text>
        <Signature class="h-10 mt-12 text-base-400" />
      </div>
      <div class="lg:ml-auto">
        {
          footerLinks.map((section) => (
            <div class="flex flex-col ">
              <Text
                tag="h4"
                variant="textXS"
                id={section.id}
                class="font-medium text-white uppercase"
              >
                {section.title}
              </Text>
              <nav
                role="navigation"
                class="flex flex-col gap-1 mt-8"
                aria-labelledby={section.id}
              >
                {section.platforms.map((platform, index) => (
                  <Text
                    tag="a"
                    variant="textXS"
                    href={platform.link}
                    aria-label={`Go to ${platform.name}`}
                    class="text-base-500 hover:underline uppercase font-medium"
                  >
                    {platform.name}
                  </Text>
                ))}
              </nav>
            </div>
          ))
        }
      </div>
      <div class="flex items-center gap-2 h-full lg:pt-12">
        <!-- This link will stick to the bottom -->
        <a href="/" class="mt-auto">
          <Logo class="h-4 text-white" />
        </a>
        <Text
          tag="span"
          class="text-xs font-semibold text-base-600"
          x-data="{ year: new Date().getFullYear() }"
        >
          © <span x-text="year"></span> Lexington Themes.
        </Text>
      </div>
    </div>
  </Wrapper>
</footer>
