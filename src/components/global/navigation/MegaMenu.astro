---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Components
import PodcastCardText from "@/components/podcast/PodcastCardText.astro";
// Content
import { getCollection } from "astro:content";

const allPodcasts = await getCollection("podcast");
allPodcasts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});

const podcastPlatforms = [
  { name: "Spotify", link: "https://open.spotify.com/show/6CBDI1nNRGpOqMFsdvJbzO?si=d4a41214c2d8412a" },
  { name: "Apple Podcasts", link: "https://podcasts.apple.com/pt/podcast/the-wac-podcast/id1739397751" },
  { name: "YouTube", link: "https://www.youtube.com/@thewacpodcast" },
];

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/podcast", label: "All Episodes" },
  { href: "/about", label: "About" },
  { href: "/community", label: "Community" },
];
---

<nav
  id="menu"
  role="navigation"
  aria-labelledby="menubutton"
  class="relative mt-8 overflow-hidden"
>
  <div class="pb-8 grid grid-cols-1 md:grid-cols-3 gap-8 border-b">
    <div class="md:col-span-2">
      <Text
        tag="a"
        href="/podcast"
        variant="textXL"
        class="font-light"
      >
        Latest Episodes
      </Text>
      <div class="flex flex-col gap-2 mt-2">
        {allPodcasts.slice(0, 3).map((post) => <PodcastCardText post={post} />)}
      </div>
    </div>
    <div class="flex flex-col gap-8">
      <div>
        <Text
          tag="p"
          variant="textXL"
          class="font-light"
        >
          Listen on
        </Text>
        <nav class="flex flex-col mt-2 gap-1">
          {
            podcastPlatforms.map((platform) => (
              <Text
                tag="a"
                variant="textXS"
                class="font-medium text-base-600 hover:underline"
                href={platform.link}
              >
                {platform.name}
              </Text>
            ))
          }
        </nav>
      </div>
      <div>
        <Text
          tag="p"
          variant="textXL"
          class="font-light"
        >
          Navigate
        </Text>
        <nav class="flex flex-col mt-2 gap-1">
          {
            navLinks.map((link) => (
              <Text
                tag="a"
                variant="textXS"
                class="font-medium text-base-600 hover:underline uppercase tracking-wide"
                href={link.href}
              >
                {link.label}
              </Text>
            ))
          }
        </nav>
      </div>
    </div>
  </div>
</nav>
<style>
  #menu {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-height 0.5s ease-out,
      opacity 0.5s ease-out;
  }
  #menu.expanded {
    max-height: 1000px;
    opacity: 1;
  }
</style>
<script type="module">
  document.addEventListener("DOMContentLoaded", () => {
    const menuButton = document.getElementById("menubutton");
    const menu = document.getElementById("menu");
    if (!menuButton || !menu) return;
    let expanded = false;
    menuButton.addEventListener("click", () => {
      expanded = !expanded;
      menuButton.setAttribute("aria-expanded", expanded);
      menu.classList.toggle("expanded", expanded);
    });
  });
</script>
