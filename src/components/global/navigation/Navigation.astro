---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const primaryNavLinks = [
  { href: "/", link: "Home" },
  { href: "/podcast", link: "Podcast" },
  { href: "/blog", link: "Blog" },
  { href: "/about", link: "About" },
  { href: "/community", link: "Community" },
];
---

<!-- Logo: pequeno em mobile, grande em desktop -->
<div class="fixed top-[6px] left-[8px] z-50 mix-blend-difference pointer-events-none">
  <a href="/" class="pointer-events-auto">
    <span class="sr-only">Wedding Artists Community</span>
    <Logo class="h-16 lg:h-36 w-auto" variant="white" />
  </a>
</div>

<!-- Nav: esconde Home em mobile para não colidir com o logo -->
<div class="fixed top-4 right-0 z-50 mix-blend-difference pointer-events-none">
  <Wrapper variant="standard">
    <nav class="flex items-center justify-end gap-4 lg:gap-6 pointer-events-auto">
      {
        primaryNavLinks.map((link) => (
          <a
            href={link.href}
            class="uppercase text-white hover:opacity-60 font-medium text-[10px] lg:text-xs tracking-wide transition-opacity"
          >
            {link.link}
          </a>
        ))
      }
    </nav>
  </Wrapper>
</div>
