---
// Assets
import Logo from "@/components/assets/Logo.astro";
import Burger from "@/components/fundations/icons/Burger.astro";
// Fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const primaryNavLinks = [
  { href: "/podcast", link: "Podcast" },
  { href: "/blog", link: "Blog" },
  { href: "/about", link: "About" },
  { href: "/community", link: "Community" },
];

const mobileNavLinks = [
  { href: "/", link: "Home" },
  { href: "/podcast", link: "Podcast" },
  { href: "/blog", link: "Blog" },
  { href: "/about", link: "About" },
  { href: "/community", link: "Community" },
];

const podcastPlatforms = [
  { name: "Spotify", link: "https://open.spotify.com/show/6CBDI1nNRGpOqMFsdvJbzO?si=d4a41214c2d8412a" },
  { name: "Apple Podcasts", link: "https://podcasts.apple.com/pt/podcast/the-wac-podcast/id1739397751" },
  { name: "YouTube", link: "https://www.youtube.com/@thewacpodcast" },
];
---

<!-- Logo: sempre fixo top-left com mix-blend-difference -->
<div class="fixed top-[6px] left-[8px] z-50 mix-blend-difference pointer-events-none">
  <a href="/" class="pointer-events-auto">
    <span class="sr-only">Wedding Artists Community</span>
    <Logo class="h-14 lg:h-36 w-auto" variant="white" />
  </a>
</div>

<!-- Nav desktop (lg+): links horizontais, escondidos em mobile -->
<div class="hidden lg:block fixed top-4 right-0 z-50 mix-blend-difference pointer-events-none">
  <Wrapper variant="standard">
    <nav class="flex items-center justify-end gap-6 pointer-events-auto">
      {
        primaryNavLinks.map((link) => (
          <a
            href={link.href}
            class="uppercase text-white hover:opacity-60 font-medium text-xs tracking-wide transition-opacity"
          >
            {link.link}
          </a>
        ))
      }
    </nav>
  </Wrapper>
</div>

<!-- Burger button: só visível em mobile (< lg) -->
<div class="lg:hidden fixed top-4 right-4 z-50 mix-blend-difference pointer-events-none">
  <button
    id="mobile-menu-button"
    aria-expanded="false"
    aria-controls="mobile-menu-overlay"
    aria-label="Abrir menu de navegação"
    class="pointer-events-auto flex items-center gap-2 text-white transition-opacity hover:opacity-60"
  >
    <span id="burger-label" class="text-[10px] font-medium uppercase tracking-wide">Menu</span>
    <Burger size="sm" />
  </button>
</div>

<!-- Mobile overlay: full-screen, z-40 (abaixo do logo/burger) -->
<div
  id="mobile-menu-overlay"
  class="lg:hidden fixed inset-0 z-40 bg-base-50 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <div class="flex flex-col h-full px-4 pt-24 pb-12 overflow-y-auto">

    <!-- Links de navegação principais: grandes, serif -->
    <nav class="flex flex-col gap-1 border-b border-base-200 pb-10">
      {
        mobileNavLinks.map((link) => (
          <a
            href={link.href}
            class="text-4xl font-serif font-light text-base-900 hover:opacity-50 transition-opacity py-1.5"
          >
            {link.link}
          </a>
        ))
      }
    </nav>

    <!-- Ouvir em / plataformas -->
    <div class="mt-10 flex flex-col gap-1">
      <p class="text-[10px] uppercase font-medium tracking-widest text-base-400 mb-3">
        Listen on
      </p>
      {
        podcastPlatforms.map((platform) => (
          <a
            href={platform.link}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-medium uppercase tracking-wide text-base-600 hover:text-base-900 transition-colors py-0.5"
          >
            {platform.name}
          </a>
        ))
      }
    </div>

  </div>
</div>

<script>
  const button = document.getElementById("mobile-menu-button");
  const overlay = document.getElementById("mobile-menu-overlay");
  const label = document.getElementById("burger-label");
  let isOpen = false;

  function toggleMenu(open?: boolean) {
    isOpen = open !== undefined ? open : !isOpen;
    button?.setAttribute("aria-expanded", String(isOpen));
    overlay?.setAttribute("aria-hidden", String(!isOpen));

    if (isOpen) {
      overlay?.classList.remove("opacity-0", "pointer-events-none");
      overlay?.classList.add("opacity-100");
      document.body.style.overflow = "hidden";
      if (label) label.textContent = "Close";
    } else {
      overlay?.classList.remove("opacity-100");
      overlay?.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
      if (label) label.textContent = "Menu";
    }
  }

  button?.addEventListener("click", () => toggleMenu());

  // Fecha ao clicar num link dentro do overlay
  overlay?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => toggleMenu(false));
  });

  // Fecha ao carregar nova página (view transitions ou popstate)
  document.addEventListener("astro:page-load", () => toggleMenu(false));
</script>
