---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getBlogPosts } from "@/lib/notion";

const posts = await getBlogPosts();
const latest = posts[0] ?? null; // artigo mais recente publicado
---

{latest && (
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <div class="flex flex-wrap items-center justify-between w-full gap-4">
        <Text tag="p" variant="textSM" class="font-medium uppercase">
          Latest article
        </Text>
        <Button
          isLink
          size="xs"
          variant="default"
          href="/blog/"
          class="w-auto text-center"
          aria-label="Read all blog posts"
          title="Read all blog posts"
        >
          Read them all
        </Button>
      </div>
      <div class="pt-4 mt-4 border-t border-black">
        <a href={`/blog/${latest.slug}`} class="group block max-w-xl">
          <Text tag="p" variant="textXS" class="uppercase text-base-400">
            {latest.publishDate && new Date(latest.publishDate).toLocaleDateString("en-US", {
              year: "numeric", month: "long", day: "2-digit"
            })}
            {latest.cluster?.length > 0 && <span> · {latest.cluster[0]}</span>}
          </Text>
          <Text tag="h2" variant="textSM" class="mt-2 font-medium group-hover:underline">
            {latest.title}
          </Text>
          {latest.excerpt && (
            <Text tag="p" variant="textSM" class="mt-1 text-base-600">
              {latest.excerpt}
            </Text>
          )}
        </a>
      </div>
    </Wrapper>
  </section>
)}
