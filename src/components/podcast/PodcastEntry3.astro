---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
const { url, title } = {
  url: "/podcast/interviews/" + Astro.props.post.slug,
  title: Astro.props.post.data.title,
};
---

<article>
  <Text
    href={url}
    title={title}
    aria-label={`Listen to: ${title}`}
    tag="a"
    variant="textSM"
    class="font-serif uppercase text-base-600 hover:underline"
  >
    {title}
  </Text>
</article>
