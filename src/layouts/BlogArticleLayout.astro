---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
import type { BlogPost } from "@/lib/notion";

interface Props {
  post: BlogPost;
  previous: BlogPost | null;
  next: BlogPost | null;
}

const { post, previous, next } = Astro.props;

const pubDate = post.publishDate
  ? new Date(post.publishDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "2-digit",
    })
  : "";
---

<BaseLayout>

  {/* ─── Hero fullscreen ─── */}
  <section class="min-h-dvh flex flex-col">
    <Wrapper variant="standard" class="flex flex-col flex-1">
      <div class="max-w-4xl mx-auto mt-auto pb-16">
        {post.cluster?.length > 0 && (
          <Text tag="p" variant="textXS" class="uppercase text-base-400 tracking-widest mb-4">
            {post.cluster.join(" · ")}
          </Text>
        )}
        <Text
          tag="h1"
          variant="display3XL"
          class="font-serif font-light tracking-tight text-base-900 text-balance"
        >
          {post.title}
        </Text>
        {post.excerpt && (
          <Text tag="p" variant="textSM" class="mt-6 max-w-4xl mx-auto text-base-600">
            {post.excerpt}
          </Text>
        )}
      </div>
    </Wrapper>
  </section>

  {/* ─── Body ─── */}
  <section>
    <Wrapper variant="standard" class="pb-32">
      <div class="border-t border-black pt-8">
        {pubDate && (
          <Text tag="p" variant="textXS" class="mb-8 uppercase text-base-400">
            <time datetime={post.publishDate}>{pubDate}</time>
          </Text>
        )}
        <Wrapper
          variant="prose"
          class="max-w-4xl mx-auto prose-h2:font-serif prose-h2:font-light prose-h2:tracking-tight prose-h2:text-5xl prose-h2:text-base-900 prose-h2:mt-16 prose-h2:mb-4 prose-blockquote:italic prose-blockquote:pl-8 prose-blockquote:font-serif prose-blockquote:font-light prose-blockquote:text-4xl prose-blockquote:leading-tight prose-blockquote:tracking-tight prose-blockquote:text-base-900 prose-blockquote:my-16"
        >
          <slot />
        </Wrapper>

        {/* ─── CTA estático ─── */}
        <div class="max-w-4xl mx-auto mt-16 pt-10 text-center">
          <Text
            tag="p"
            variant="displaySM"
            class="font-serif font-light text-base-900 text-balance leading-snug"
          >
            If this resonated, explore more articles in{" "}
            <a href="/blog" class="underline underline-offset-4 hover:opacity-60 transition-opacity">The WAC Blog</a>,
            or listen to{" "}
            <a href="/podcast" class="underline underline-offset-4 hover:opacity-60 transition-opacity">The WAC Podcast</a>,
            where we go deeper into the business of being a wedding professional in Europe.
          </Text>
          <div class="flex justify-center mt-8">
            <ShareButtons contentType="blog" description={post.excerpt || post.title} />
          </div>
        </div>
      </div>
    </Wrapper>
  </section>

  {/* ─── Prev / Next ─── */}
  <Wrapper variant="standard" class="pb-24 pt-4">
    <nav class="flex flex-col md:flex-row lg:justify-between gap-4 lg:items-center text-xs pt-8">
      {previous && (
        <a href={`/blog/${previous.slug}`} class="hover:opacity-80">
          <span class="block text-base-900 font-medium uppercase">Previous:</span>
          <span class="block text-base-600">{previous.title}</span>
        </a>
      )}
      {next && (
        <a href={`/blog/${next.slug}`} class="hover:opacity-80 text-right">
          <span class="block text-base-900 font-medium uppercase">Next:</span>
          <span class="block text-base-600">{next.title}</span>
        </a>
      )}
    </nav>
  </Wrapper>

</BaseLayout>
