---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Authors entries
import AuthorCard from "@/components/authors/AuthorCard.astro";
// Get all authors
import { getCollection } from "astro:content";
const allAuthors = await getCollection("authors");
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="max-w-3xl">
        <Text
          tag="h1"
          variant="displayMD"
          class="font-serif font-light leading-6 md:leading-8 text-base-600"
        >
          <span class="text-base-900">Meet the Authors and Hosts:</span> Discover
          the creative minds behind our blogs and podcasts. From sharing expert insights
          on design and development to exploring trends in technology and innovation,
          these voices bring knowledge, passion, and personality to every piece of
          content.
        </Text>
      </div>

      <div
        class="pt-2 mt-24 border-t border-black grid grid-cols-1 md:grid-cols-2 gap-2"
      >
        {allAuthors.map((post) => <AuthorCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
