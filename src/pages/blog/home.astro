---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Link from "@/components/fundations/elements/Link.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Sections
import BlogHero2 from "@/components/blog/BlogHero2.astro";
import Subscribe from "@/components/blog/Subscribe.astro";
// Blog entries
import BlogEntry1 from "@/components/blog/BlogEntry1.astro";
import BlogEntry2 from "@/components/blog/BlogEntry2.astro";
// Get all posts
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime(); // Convert to timestamp
  const dateB = new Date(b.data.pubDate).getTime(); // Convert to timestamp
  return dateB - dateA; // Compare timestamps
});
---

<BaseLayout>
  <BlogHero2 />
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <div
        class="items-start pt-4 border-t border-black grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-x-4 gap-y-12"
      >
        {allPosts.map((post) => <BlogEntry1 post={post} />)}
      </div>
    </Wrapper>
  </section>
  
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <Text tag="p" variant="textSM" class="font-medium uppercase">
        Subscribers only
      </Text>
      <div
        class="items-start pt-4 mt-4 border-t border-black grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-12 gap-2"
      >
        {
          allPosts
            .filter((post) => post.data.isLocked)
            .map((post) => <BlogEntry2 post={post} />)
        }
      </div>
    </Wrapper>
  </section>
  <Subscribe />
</BaseLayout>
