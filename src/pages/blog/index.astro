---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Subscribe from "@/components/ctas/Subscribe.astro";
import { getBlogPosts } from "@/lib/notion";

const posts = await getBlogPosts();

function fmtDate(d: string) {
  return d ? new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "2-digit" }) : "";
}
---

<BaseLayout>
  <section class="bg-base-900">
    <Wrapper variant="standard" class="pt-70 pb-24">
      <div class="max-w-4xl">
        <Text tag="p" variant="textXS" class="font-medium uppercase text-white/50 mb-6 tracking-widest">
          The WAC Blog
        </Text>
        <Text tag="h1" variant="displayMD" class="font-serif font-light text-white/60">
          <span class="italic text-white">Industry insight,</span> craft, and
          community — for wedding professionals who think deeply about their work.
        </Text>
      </div>
    </Wrapper>
  </section>

  {posts.length === 0 ? (
    <section>
      <Wrapper variant="standard" class="py-24">
        <Text tag="p" variant="textSM" class="text-base-400">No articles published yet.</Text>
      </Wrapper>
    </section>
  ) : (
    <section>
      <Wrapper variant="standard" class="pt-16 pb-24">
        <Text tag="p" variant="textSM" class="font-medium uppercase">All articles</Text>
        <div class="items-start pt-4 mt-4 border-t border-black grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="relative group">
              <a href={`/blog/${post.slug}`} class="absolute inset-0 z-10" aria-label={post.title}></a>
              <div>
                {post.cluster?.length > 0 && (
                  <Text tag="p" variant="textXS" class="uppercase text-base-400 mb-2">
                    {post.cluster[0]}
                  </Text>
                )}
                <Text tag="h2" variant="textSM" class="font-medium group-hover:underline">
                  {post.title}
                </Text>
                {post.excerpt && (
                  <Text tag="p" variant="textSM" class="mt-1 text-base-600">
                    {post.excerpt}
                  </Text>
                )}
                <Text tag="p" variant="textXS" class="mt-3 uppercase text-base-400">
                  <time datetime={post.publishDate}>{fmtDate(post.publishDate)}</time>
                </Text>
              </div>
            </article>
          ))}
        </div>
      </Wrapper>
    </section>
  )}

  <Subscribe />
</BaseLayout>
